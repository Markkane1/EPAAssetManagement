{
  "name": "ams-server",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate:offices:legacy-import": "node scripts/migrate-offices.js",
    "migrate:offices:normalize-types": "tsx scripts/migrate-offices-to-new-types.ts",
    "seed:store": "tsx scripts/seed-head-office-store.ts",
    "seed:consumables": "tsx scripts/seed-consumables.ts",
    "migrate:assetitem-holders": "tsx scripts/migrate-assetitems-holder-fields.ts",
    "migrate:transfer-lines": "tsx scripts/migrate-transfers-to-lines.ts",
    "migrate:maintenance-legacy": "tsx scripts/backfill-maintenance-legacy-fields.ts",
    "migrate:search-terms": "tsx scripts/backfill-search-term-indexes.ts",
    "openapi:generate": "node scripts/generate-openapi.js",
    "test:suite": "node scripts/run-test-suites.js",
    "test:security": "node scripts/run-test-suites.js security",
    "test:consumables": "node scripts/run-test-suites.js consumables",
    "test:requisition": "node scripts/run-test-suites.js requisition",
    "test:returns": "node scripts/run-test-suites.js returns",
    "test:reports": "node scripts/run-test-suites.js reports",
    "test:transfers": "node scripts/run-test-suites.js transfers",
    "test:employees": "node scripts/run-test-suites.js employees",
    "test:office": "node scripts/run-test-suites.js office",
    "test:asset-items": "node scripts/run-test-suites.js assetItems",
    "test:runtime": "node scripts/run-test-suites.js runtime",
    "test:all": "node scripts/run-test-suites.js all",
    "test:manual:assignment-slip": "tsx ../tests/integration/manual/generate-assignment-slip.manual-test.ts",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "xss-clean": "^0.1.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
